{
  "compilerOptions": {
    "outDir": "dist",
    "sourceMap": true,
    "target": "es2016",
    "module": "esnext",
    "moduleResolution": "node",
    "strict": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "jsx": "preserve", // jsx不转义
    "lib": ["es2016", "dom"],
    "baseUrl": ".",
    "paths":{
      "@vue/*":["packages/*/src"]
    }
  }
}