{
  "compilerOptions": {
    "target": "es2016",
    "jsx": "preserve", // jsx不转义
    "lib": ["es2016", "dom"],
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "node",
    "paths": {
      "@vue/*": ["packages/*/src"]
    },
    "resolveJsonModule": true,
    "strict": false,
    "outDir": "dist",
    "sourceMap": true,
    "esModuleInterop": true
  }
}
